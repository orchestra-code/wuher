{
  "name": "wuher",
  "version": "1.1.1",
  "description": "A robots.txt parser that classifies bot access rules. Named after the Mos Eisley cantina bartender who told Luke, \"Your droids. They can't come in here.\"",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && npm publish --access public",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "robots.txt",
    "robots",
    "crawler",
    "bot",
    "ai",
    "chatgpt",
    "claude",
    "parser",
    "seo",
    "web-crawling",
    "cloudflare",
    "web-bot-auth",
    "sitemap"
  ],
  "author": "Orchestra AI, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicholasoxford/wuher.git"
  },
  "bugs": {
    "url": "https://github.com/nicholasoxford/wuher/issues"
  },
  "homepage": "https://github.com/nicholasoxford/wuher#readme",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
